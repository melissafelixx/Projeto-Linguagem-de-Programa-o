/* 6. CONSULTAR SALDO */
/* Mostra o saldo da conta atualmente logada */
/* ------ */
void consultar_saldo() {
    printf("\n" COR_CIANO "--- CONSULTAR SALDO ---" COR_RESET "\n");
    
    if (conta_logada == -1) {
        printf(COR_VERMELHO "Faca login primeiro (opcao 2)." COR_RESET "\n");
        return;
    }
    
    printf("\nTitular: %s\n", nome[conta_logada]);
    printf("Conta : %d\n", num_conta[conta_logada]);
    printf(COR_VERDE "Saldo : R$ %.2f" COR_RESET "\n", saldo[conta_logada]);
}
 
/* ------ */
/* 7. EXTRATO (mostra os dados e o historico da conta logada) */
/* ------ */
void extrato() {
    int i;
    
    printf("\n" COR_CIANO "--- EXTRATO ---" COR_RESET "\n");
    
    if (conta_logada == -1) {
        printf(COR_VERMELHO "Faca login primeiro (opcao 2)." COR_RESET "\n");
        return;
    }
    
    printf("Titular: %s\n", nome[conta_logada]);
    printf("Conta : %d\n", num_conta[conta_logada]);
    printf(COR_VERDE "Saldo : R$ %.2f" COR_RESET "\n", saldo[conta_logada]);
    
    printf("\n" COR_NEGRITO "Ultimas transacoes:" COR_RESET "\n");
    if (qtd_historico[conta_logada] == 0) {
        printf(COR_AMARELO "Nenhuma transacao registrada ainda." COR_RESET "\n");
        return;
    }
    
    /* mostra da mais recente pra mais antiga */
    for (i = qtd_historico[conta_logada] - 1; i >= 0; i--) {
        printf(" - %s\n", historico[conta_logada][i]);
    }
}

/* ------ */
/* 8. FAZER LOGOUT */
/* Sai da conta logada, mas mantem o sistema aberto */
/* ------ */
void fazer_logout() {
    printf("\n" COR_CIANO "--- FAZER LOGOUT ---" COR_RESET "\n");
    
    if (conta_logada == -1) {
        printf(COR_AMARELO "Nenhuma conta logada." COR_RESET "\n");
        return;
    }
    
    printf(COR_VERDE "Logout realizado. Ate logo, %s!" COR_RESET "\n", nome[conta_logada]);
    conta_logada = -1;
    
}
 
