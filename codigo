reset -> usado pra voltar a cor padrão. */
#define COR_RESET "\033[0m"
#define COR_VERMELHO "\033[1;31m"
#define COR_VERDE "\033[1;32m"
#define COR_AMARELO "\033[1;33m"
#define COR_CIANO "\033[1;36m"
#define COR_NEGRITO "\033[1m"
 
/* ─── Constantes ─────────────────────────────────────────── */
#define MAX_CONTAS 10
#define TAM_NOME 50
#define TAM_SENHA 20
#define TAM_DATA 20
#define MAX_HISTORICO 5 /* quantas transacoes guardamos por conta */
#define TAM_HIST 120
#define MAX_TENTATIVAS 3 /* tentativas de senha antes de bloquear */
#define TEMPO_BLOQUEIO 30 /* tempo de bloqueio, em segundos */
 
/* ─── Estrutura de dados ──────────────────────────────────── */
