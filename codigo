char senha[MAX_CONTAS][TAM_SENHA];
float saldo[MAX_CONTAS];
int total_contas = 0;
 
/*  Historico de transacoes Guarda as ultimas MAX_HISTORICO movimentacoes de cada conta,sempre com data/hora, da mais antiga para a mais recente.*/
char historico[MAX_CONTAS][MAX_HISTORICO][TAM_HIST];
int qtd_historico[MAX_CONTAS];
 
/*  sistema de tentativa de logins (quantas tentativas pode fazer e o tempo de bloqueio) */
int tentativas_login[MAX_CONTAS];
time_t bloqueio_login[MAX_CONTAS];
 
/*  Sistema de login só permite 1 conta logada por vez (qnd ta -1 é pq n tem conta nenhuma logada no momento) */
int conta_logada = -1;
 
